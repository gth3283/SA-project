--- !u!114 &1726442557
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1726442553}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 47854c7387107d74d8518ce4c20d8733, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  t:
    sentences:
    - 
    - 
    - "\uC0AC\uB2F9 \uB098\uBB34\uC5D0\uC11C \uB9C8\uC744\uC5D0 \uD574\uC545\uC744
      \uB07C\uCE58\uB294 \uAD6C\uC2AC\uC744 \uD68C\uC218. \uCD1D \uB2E4\uC12F \uAC1C.
      \uC774\uC7A5\uB2D8\uACFC \uB0B4\uAC00 \uB098\uB204\uC5B4 \uBCF4\uAD00\uD558\uAE30\uB85C
      \uACB0\uC815."
    - "\uAD6C\uC2AC \uBD84\uC2E4. \uC138 \uAC1C\uAC00 \uC0AC\uB77C\uC84C\uB2E4. \uC758\uC2EC
      \uAC00\uB294 \uC778\uBB3C\uC740 \uAE40\uC528, \uC774\uC528, \uB2F9\uC528\uC758
      \uC544\uC774. \uC900\uBE44 \uD6C4 \uC870\uC0AC \uC608\uC815"
    - "\uAE40\uC528, \uC774\uC528, \uB2F9\uC528\uC758 \uC544\uC774 \uBAA8\uB450 \uC0AC\uB77C\uC9D0.
      \uC218\uC0C9\uC744 \uD53C\uD574 \uB3C4\uB9DD\uAC14\uB2E4? \uC2E4\uC885\uC790\uB85C
      \uCC98\uB9AC\uD574 \uC218\uC0C9 \uC2DC\uC791\uD568."
    - "\uB9C8\uC744\uC5D0 \uC774\uC0C1\uD604\uC0C1\uC774 \uC788\uB2E4. \uBAA8\uB450
      \uAC81\uC5D0 \uC9C8\uB824 \uC218\uC0C9\uC5D0 \uCC38\uC5EC\uD558\uC9C0 \uC54A\uC74C.
      \uC218\uC0C9 \uAE30\uAC04\uC774 \uB298\uC5B4\uB0A0 \uAC83 \uAC19\uB2E4.\r\n\uCD0C\uC7A5\uB2D8\uB3C4
      \uC0C1\uD0DC\uAC00 \uC88B\uC9C0 \uBABB\uD558\uC2DC\uB2E4. *\uC744 \uC783\uC740
      \uC2AC\uD514 \uB54C\uBB38\uC778 \uB4EF.\r"
    - "\uB450 \uBC88\uC9F8 \uC77C\uC9C0\uB97C \uD3BC\uCCE4\uB2E4."
    - "\uCD0C\uC7A5\uB2D8\uC774 \uC9D1\uC744 \uBE44\uC6CC\uB3C4 \uD544\uC694\uD560
      \uB54C \uB4E4\uC5B4\uAC08 \uC218 \uC788\uB294 \uBC29\uBC95\uC744 \uC54C\uB824\uC8FC\uC2EC.
      \uC9D1 \uB05D \uB450 \uAC1C\uC758 \uCC3D\uBB38 \uC911 \uC624\uB978\uCABD \uCC3D\uBB38\uC740
      \uC7A0\uADF8\uC9C0 \uC54A\uC740 \uC0C1\uD0DC\uB85C \uC720\uC9C0"
    name:
    - "~\uB9C8\uC744\uAD00\uB9AC\uC77C\uC9C0~"
    - "[\uCCAB \uBC88\uCA30 \uC77C\uC9C0]"
    - "19xx\uB144 12\uC6D4 1\uC77C"
    - "1977\uB144 12\uC6D4 3\uC77C"
    - "1977\uB144 12\uC6D4 4\uC77C"
    - "1977\uB144 12\uC6D4 5\uC77C"
    - 
    - "1972\uB144 "
